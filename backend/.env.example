# Backend Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Connection
MONGO_URI=mongodb://mongodb:27017/online-judge

# Security Secrets (Change these in production!)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Internal service key — must match JUDGE_SERVICE_KEY in compiler/.env
# Used by the compiler service to fetch hidden test cases for judging
JUDGE_SERVICE_KEY=your-internal-service-key-change-this

# Frontend URL (For CORS)
FRONTEND_URL=http://localhost:5173

# Compiler Service URL
COMPILER_SERVICE_URL=http://localhost:8000

# AI Service (Get a free key from aistudio.google.com)
GEMINI_API_KEY=your-gemini-api-key-here
